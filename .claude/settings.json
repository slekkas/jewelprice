{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --abbrev-ref --symbolic-full-name @{u} >/dev/null 2>&1 && git pull --ff-only 2>&1 || true",
            "statusMessage": "Pulling latest from GitHub..."
          }
        ]
      }
    ]
  }
}
